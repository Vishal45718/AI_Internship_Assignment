# ─────────────────────────────────────────────────────────────────────────────
# RAG System — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
LLM_PROVIDER=gemini

# Google Gemini (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash-8b

# Ollama (required if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# ── Embedding ────────────────────────────────────────────────────────────────
# Local sentence-transformer model (no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Vector Store ─────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/vectorstore
CHROMA_COLLECTION_NAME=rag_documents

# ── Retrieval ────────────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
FINAL_CONTEXT_CHUNKS=2
MAX_CONTEXT_TOKENS=300
LLM_MAX_OUTPUT_TOKENS=64
RETRIEVAL_SCORE_THRESHOLD=0.55
RERANK_SCORE_THRESHOLD=0.20
SIMILARITY_THRESHOLD=0.70
HYBRID_SEARCH_ENABLED=false
PARENT_CONTEXT_ENABLED=false
PARENT_WINDOW_BEFORE=1
PARENT_WINDOW_AFTER=1
PARENT_EXPAND_FULL_SECTION=false

# ── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=180
CHUNK_OVERLAP=80

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
