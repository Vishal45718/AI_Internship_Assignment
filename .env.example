# ─────────────────────────────────────────────────────────────────────────────
# Agentic RAG System — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: "openai" | "gemini" | "ollama"
LLM_PROVIDER=openai

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google Gemini (required if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-1.5-flash

# Ollama (required if LLM_PROVIDER=ollama — run Ollama locally first)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ── Embedding ────────────────────────────────────────────────────────────────
# Override to use a local sentence-transformer instead of OpenAI embeddings
EMBEDDING_PROVIDER=openai
# For local embeddings: sentence-transformers/all-MiniLM-L6-v2
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Vector Store ─────────────────────────────────────────────────────────────
VECTOR_DB=chroma
CHROMA_PERSIST_DIR=./data/vectorstore
CHROMA_COLLECTION_NAME=agentic_rag

# ── Retrieval Tuning ─────────────────────────────────────────────────────────
RETRIEVAL_TOP_K=10
RERANK_TOP_N=3
SIMILARITY_THRESHOLD=0.35
CONFIDENCE_THRESHOLD=0.40
ENABLE_RERANKING=true
ENABLE_QUERY_EXPANSION=false

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=1500
CHUNK_OVERLAP=200

# ── Conversation Memory ───────────────────────────────────────────────────────
MAX_CONVERSATION_TURNS=6

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ── Paths ────────────────────────────────────────────────────────────────────
DATA_DIR=./data/raw
PROCESSED_DIR=./data/processed
