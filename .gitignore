# ─────────────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
build/
dist/

# ─────────────────────────────────────────────────────────────────────────────
# Virtual environments
# ─────────────────────────────────────────────────────────────────────────────
.venv/
venv/
env/
.env            # Secrets — never commit

# ─────────────────────────────────────────────────────────────────────────────
# Data (vector store — not committed to git)
# ─────────────────────────────────────────────────────────────────────────────
data/vectorstore/

# ─────────────────────────────────────────────────────────────────────────────
# IDE
# ─────────────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# ─────────────────────────────────────────────────────────────────────────────
# Testing & coverage
# ─────────────────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ─────────────────────────────────────────────────────────────────────────────
# Model cache
# ─────────────────────────────────────────────────────────────────────────────
.cache/

# ─────────────────────────────────────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────────────────────────────────────
*.log
.env
data/app.db
data/raw/*.pdf
